# Version control
.git/
.gitignore

# Frontend build artifacts & noise (source is needed for the frontend stage)
frontend/node_modules/
frontend/dist/
frontend/*.log
frontend/.DS_Store

# Python artifacts
__pycache__/
**/__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Local environment
.env
.env.*

# IDE
.vscode/
.idea/

# Test data & docs (not needed in production image)
test_images/
tests/
docs/
*.md

# Docker files
Dockerfile
docker-compose.yml
.dockerignore

# Local data volumes
minio_data/
postgres_data/
storage/
images/

# Gemini/AI artifacts
.gemini/
