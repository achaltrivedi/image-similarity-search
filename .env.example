# Image Similarity Service Configuration

# --- Database ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=vectordb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- MinIO (Object Storage) ---
# Server admin credentials (used by MinIO server itself)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# API access credentials (used by our app to connect to MinIO)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=image-similarity-test
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- Redis (Queue) ---
REDIS_URL=redis://redis:6379/0

# --- Application ---
INGEST_QUEUE_BACKEND=rq
INGEST_QUEUE_NAME=minio_ingestion

# --- ML Models ---
HF_TOKEN=
