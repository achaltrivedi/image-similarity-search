{
    "CORSRules": [
        {
            "AllowedHeaders": ["*"],
            "AllowedMethods": ["GET", "PUT", "POST", "DELETE", "HEAD"],
            "AllowedOrigins": [
                "http://localhost",
                "http://localhost:80",
                "http://localhost:5173",
                "http://localhost:5174",
                "http://127.0.0.1",
                "http://127.0.0.1:80",
                "http://127.0.0.1:5173"
            ],
            "ExposeHeaders": ["ETag", "Content-Length", "Content-Type"],
            "MaxAgeSeconds": 3600
        }
    ]
}
